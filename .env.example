# ------------------------------
# Common Runtime
# ------------------------------
ENV=dev
TZ=Asia/Shanghai

# ------------------------------
# Model / Vector
# ------------------------------
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
CHROMA_DIR=/data/chroma
CHROMA_COLLECTION=campus_docs

# ------------------------------
# AI Service
# ------------------------------
AI_SERVICE_PORT=8000
MAX_STEPS=5
MEMORY_PATH=/data/session_memory.json
LANGGRAPH_STATE_DB=/data/langgraph_state.db
TOOL_TIMEOUT_SECONDS=8
TOOL_RETRY_ATTEMPTS=2
TOOL_RETRY_BACKOFF_SECONDS=0.4
TOOL_CIRCUIT_BREAKER_THRESHOLD=3
TOOL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# ------------------------------
# Java Backend
# ------------------------------
JAVA_BACKEND_PORT=8080
AI_SERVICE_URL=http://ai-service:8000
REDIS_HOST=redis
REDIS_PORT=6379
SESSION_TTL_SECONDS=86400
JWT_SECRET=replace-with-at-least-32-characters-secret-key
JWT_EXPIRES_SECONDS=7200
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123456

# ------------------------------
# Observability
# ------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
